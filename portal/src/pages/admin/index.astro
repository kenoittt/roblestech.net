---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { createSupabaseServer, createSupabaseAdmin } from '../../lib/supabase';

const supabase = createSupabaseServer(Astro);

type Client = { id: string; name: string; gsc_property: string | null; config: unknown };
const { data } = await supabase
  .from('clients')
  .select('id, name, gsc_property, config')
  .order('name');
const clients: Client[] = (data as Client[]) ?? [];

// Client logins and which company each is linked to (drives dashboard access).
const adminClient = createSupabaseAdmin();
const { data: clientProfiles } = await adminClient
  .from('profiles').select('id, full_name, client_id').eq('role', 'client').order('full_name');
const { data: userList } = await adminClient.auth.admin.listUsers({ page: 1, perPage: 1000 });
const emailById = new Map((userList?.users ?? []).map((u) => [u.id, u.email ?? '']));
type CP = { id: string; full_name: string | null; client_id: string | null };
const logins: CP[] = (clientProfiles as CP[]) ?? [];
// Only logins that still need a company (once assigned they drop off this list).
const unassignedLogins = logins.filter((l) => !l.client_id);

const ok = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');

const pretty = (c: unknown) => {
  try {
    const obj = c && Object.keys(c as object).length ? c : SAMPLE_CONFIG;
    return JSON.stringify(obj, null, 2);
  } catch {
    return '{}';
  }
};
// Shown when a client has no config yet — a minimal starting point.
const SAMPLE_CONFIG = {
  brand: { brand: '#53001C', 'brand-dark': '#3E0016', accent: '#34657F' },
  hero: { eyebrow: 'Client Name · SEO + GEO', title: 'Post Performance & GEO Dashboard' },
  baseline: {},
  aiAudit: {},
  pipeline: [],
  sopSteps: [],
  openItems: [],
};

const role = Astro.locals.profile?.role;
const isSuper = role === 'super_admin';
let pending: any[] = [];
if (isSuper) {
  const { data: pr } = await adminClient
    .from('change_requests')
    .select('id, kind, payload, reason, requested_by, requested_at')
    .eq('status', 'pending')
    .order('requested_at', { ascending: true });
  pending = pr ?? [];
}
const kindLabel: Record<string, string> = {
  client_create: 'Add client', client_update: 'Edit client', client_delete: 'Delete client',
  link_client: 'Change client access', save_config: 'Edit dashboard content',
};
---

<PortalLayout title="Admin · Robles Tech Portal">
  <p class="eyebrow">Admin Panel</p>
  <h1>Manage clients &amp; dashboards</h1>
  <p class="lede">Create clients and logins, set each client's Search Console property and branding, and edit their dashboard content.</p>

  {ok && <div class="alert alert-ok">{ok}</div>}
  {err && <div class="alert alert-error">{err}</div>}

  {!isSuper && (
    <div class="alert" style="background:rgba(57,146,255,0.12);border:1px solid rgba(57,146,255,0.4);color:#cfe2ff;">
      You're an <b>admin</b>. You can view everything and submit changes, but add/edit/delete actions
      need <b>super-admin approval</b> — you'll be asked for a note when you submit.
    </div>
  )}

  {isSuper && pending.length > 0 && (
    <div class="section-gap" style="margin-top:0;margin-bottom:28px;">
      <h2>Pending approvals <span class="hint" style="font-weight:600;">· {pending.length}</span></h2>
      {pending.map((p) => (
        <div class="card" style="margin-bottom:12px;display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center;">
          <div>
            <div style="font-weight:700;">{kindLabel[p.kind] ?? p.kind}</div>
            <div class="hint" style="margin:4px 0;">by {emailById.get(p.requested_by) || 'unknown'} · {new Date(p.requested_at).toLocaleString()}</div>
            {p.reason && <div style="font-size:.85rem;color:#cfe2ff;">“{p.reason}”</div>}
            <div class="hint" style="margin-top:4px;">{JSON.stringify(p.payload)}</div>
          </div>
          <div style="display:flex;gap:8px;">
            <form method="post" action="/api/approve-request"><input type="hidden" name="id" value={p.id} /><input type="hidden" name="decision" value="approve" /><button class="btn" type="submit">Approve</button></form>
            <form method="post" action="/api/approve-request"><input type="hidden" name="id" value={p.id} /><input type="hidden" name="decision" value="reject" /><button class="btn-danger" type="submit">Reject</button></form>
          </div>
        </div>
      ))}
    </div>
  )}

  <div class="admin-grid">
    <div class="admin-col">
      <h2>1 · Add a client</h2>
      <form method="post" action="/api/create-client" class="form-grid card gated">
        <div>
          <label for="c-name">Company name</label>
          <input id="c-name" name="name" type="text" required placeholder="Promix Nutrition" />
        </div>
        <div>
          <label for="c-gsc">GSC property</label>
          <input id="c-gsc" name="gsc_property" type="text" placeholder="https://promixnutrition.com/" />
          <p class="hint">URL-prefix e.g. <code>https://site.com/</code> or domain e.g. <code>sc-domain:site.com</code>.</p>
        </div>
        <button class="btn" type="submit">Create client</button>
      </form>
    </div>

    {isSuper && (
    <div class="admin-col">
      <h2>2 · Create a client login</h2>
      <form method="post" action="/api/create-login" class="form-grid card">
        <div>
          <label for="l-client">Client</label>
          <select id="l-client" name="client_id" required>
            <option value="" disabled selected>Select a client…</option>
            {clients.map((c) => <option value={c.id}>{c.name}</option>)}
          </select>
        </div>
        <div>
          <label for="l-name">Contact name (optional)</label>
          <input id="l-name" name="full_name" type="text" placeholder="Jane Doe" />
        </div>
        <div>
          <label for="l-email">Email</label>
          <input id="l-email" name="email" type="email" required placeholder="jane@promix.com" />
        </div>
        <div>
          <label for="l-pass">Password</label>
          <input id="l-pass" name="password" type="text" required minlength="8" placeholder="At least 8 characters" />
          <p class="hint">You'll share this with the client.</p>
        </div>
        <button class="btn" type="submit">Create login</button>
      </form>
    </div>
    )}
  </div>

  {isSuper && (
  <div class="section-gap">
    <h2>Team</h2>
    <div class="card">
      <p style="margin:0 0 16px;">Create additional Robles Tech admin logins (full panel access).</p>
      <a class="btn" href="/admin/create-admin">Create an admin →</a>
    </div>
  </div>
  )}

  <div class="section-gap">
    <h2>Client access <span class="hint" style="font-weight:600;">· logins waiting to be enabled</span></h2>
    <p class="hint" style="margin-bottom:16px;">
      New client logins appear here until you link them to a company (which enables their dashboard).
      Once assigned they drop off this list — manage everyone anytime on the
      <a href="/admin/clients" style="color:var(--lime);">Clients page →</a>
    </p>
    {unassignedLogins.length === 0 && <p class="hint">All client logins are assigned. 🎉</p>}
    {unassignedLogins.map((lg) => (
      <form method="post" action="/api/link-client" class="card gated" style="display:flex;gap:14px;align-items:end;flex-wrap:wrap;margin-bottom:12px;">
        <input type="hidden" name="user_id" value={lg.id} />
        <div style="flex:1;min-width:200px;">
          <label>{lg.full_name || '(no name)'}</label>
          <div class="hint" style="margin:0 0 6px;">{emailById.get(lg.id) || lg.id.slice(0, 8)}</div>
        </div>
        <div style="min-width:220px;">
          <label>Company (dashboard)</label>
          <select name="client_id">
            <option value="">None (disabled)</option>
            {clients.map((c) => <option value={c.id} selected={lg.client_id === c.id}>{c.name}</option>)}
          </select>
        </div>
        <button class="btn" type="submit">Save</button>
      </form>
    ))}
  </div>

  <div class="section-gap">
    <h2>3 · Dashboard content &amp; GSC (per client)</h2>
    <p class="hint" style="margin-bottom:16px;">
      The GSC numbers refresh automatically every day. Everything else — brand colors, hero text,
      the frozen baseline, and the AI-visibility audit text — lives in each client's <b>config</b> below.
      Paste the config JSON your Claude workflow produces, or edit it here to add custom audit text.
    </p>

    {clients.length === 0 && <p class="hint">No clients yet — add one above.</p>}

    {
      clients.map((c) => (
        <details class="card" style="margin-bottom:14px;">
          <summary style="cursor:pointer;font-weight:700;font-size:1.05rem;">
            {c.name}
            <a href={`/d?client=${c.id}`} target="_blank" rel="noopener" style="float:right;color:var(--lime);font-size:.85rem;">Preview dashboard →</a>
          </summary>
          <form method="post" action="/api/save-config" class="form-grid gated" style="max-width:none;margin-top:16px;">
            <input type="hidden" name="client_id" value={c.id} />
            <div>
              <label>GSC property</label>
              <input name="gsc_property" type="text" value={c.gsc_property ?? ''} placeholder="https://site.com/" />
            </div>
            <div>
              <label>Config (JSON) — branding, hero, baseline, aiAudit, pipeline, openItems</label>
              <textarea name="config" spellcheck="false">{pretty(c.config)}</textarea>
              <p class="hint">To change the AI audit or any narrative, edit it here. Do not put GSC daily numbers here — those come from the automatic pull.</p>
            </div>
            <button class="btn" type="submit">Save content</button>
          </form>
        </details>
      ))
    }
  </div>

  <script is:inline define:vars={{ isSuper }}>
    // Regular admins: gated actions become approval requests — prompt for a note.
    if (!isSuper) {
      document.querySelectorAll('form.gated').forEach((f) => {
        f.addEventListener('submit', (e) => {
          const note = window.prompt('This change needs super-admin approval.\nAdd a short note describing your request:');
          if (note === null) { e.preventDefault(); return; }
          let inp = f.querySelector('input[name="reason"]');
          if (!inp) { inp = document.createElement('input'); inp.type = 'hidden'; inp.name = 'reason'; f.appendChild(inp); }
          inp.value = note;
        });
      });
    }
  </script>
</PortalLayout>
