---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { createSupabaseServer } from '../../lib/supabase';

const clientId = Astro.url.searchParams.get('client') ?? '';
const supabase = createSupabaseServer(Astro);
const { data: client } = await supabase.from('clients').select('id, name, config').eq('id', clientId).single();
if (!client) return Astro.redirect('/admin/clients');

const cfg: any = ((client as any).config && typeof (client as any).config === 'object') ? (client as any).config : {};
const baseline = cfg.baseline ?? {};
const pages = Array.isArray(baseline.pages) ? baseline.pages : [];
const pipeline = Array.isArray(cfg.pipeline) ? cfg.pipeline : [];
const openItems = Array.isArray(cfg.openItems) ? cfg.openItems : [];
const isSuper = Astro.locals.profile?.role === 'super_admin';

// Monthly AI-audit report files for this client.
type Audit = { id: string; title: string; period: string };
const { data: auditRows } = await supabase
  .from('reports').select('id, title, period').eq('client_id', clientId).order('period', { ascending: false });
const audits: Audit[] = (auditRows as Audit[]) ?? [];
const monthName = (p: string) => new Date(p + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });

const ok = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');
const v = (x: any) => (x === undefined || x === null ? '' : String(x));
---

<PortalLayout title={`Edit content · ${(client as any).name}`}>
  <p class="eyebrow">Admin · Dashboard content</p>
  <h1>{(client as any).name}</h1>
  <p class="lede">Edit the manual parts of this client's dashboard. <a href="/admin" style="color:var(--lime);">← Back to admin</a></p>
  {ok && <div class="alert alert-ok">{ok}</div>}
  {err && <div class="alert alert-error">{err}</div>}
  {!isSuper && <div class="alert" style="background:rgba(57,146,255,0.12);border:1px solid rgba(57,146,255,0.4);color:#cfe2ff;">Your changes here are submitted for super-admin approval.</div>}

  <form method="post" action="/api/save-content" class="gated">
    <input type="hidden" name="client_id" value={clientId} />

    <div class="section-h">Baseline (pre-service “before” numbers)</div>
    <div class="card" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
      <div><label>Window</label><input name="bl_window" value={v(baseline.window)} placeholder="June 1 - 30, 2026" /></div>
      <div><label>Service start</label><input name="bl_serviceStart" value={v(baseline.serviceStart)} placeholder="July 1, 2026" /></div>
      <div><label>Captured</label><input name="bl_captured" value={v(baseline.captured)} placeholder="2026-07-18" /></div>
      <div><label>Clicks</label><input name="bl_clicks" value={v(baseline.clicks)} inputmode="numeric" /></div>
      <div><label>Impressions</label><input name="bl_impr" value={v(baseline.impr)} inputmode="numeric" /></div>
      <div><label>Avg CTR</label><input name="bl_ctr" value={v(baseline.ctr)} placeholder="4.1%" /></div>
      <div><label>Avg position</label><input name="bl_avgPos" value={v(baseline.avgPos)} placeholder="7.9" /></div>
      <div><label>Posts live (RTC)</label><input name="bl_postsLive" value={v(baseline.postsLive)} inputmode="numeric" /></div>
      <div><label>AI citations text</label><input name="bl_aiText" value={v(baseline.aiText)} placeholder="5 / 40" /></div>
      <div style="grid-column:1/-1;"><label>AI sub-note</label><input name="bl_aiSub" value={v(baseline.aiSub)} placeholder="June audit, 10 Qs x 4 engines (12.5%)" /></div>
    </div>

    <div class="section-h">Top pages at baseline</div>
    <div id="pagesList"></div>
    <button type="button" class="mini js-add" data-list="pages">+ Add page</button>

    <div class="section-h">Content pipeline</div>
    <div id="pipeList"></div>
    <button type="button" class="mini js-add" data-list="pipe">+ Add post</button>

    <div class="section-h">Open items</div>
    <div id="oiList"></div>
    <button type="button" class="mini js-add" data-list="oi">+ Add item</button>

    <input type="hidden" name="bl_pages" id="f-pages" />
    <input type="hidden" name="pipeline" id="f-pipe" />
    <input type="hidden" name="openItems" id="f-oi" />
    <div style="margin-top:22px;"><button class="btn" type="submit">Save content</button></div>
  </form>

  <div class="section-h">AI Visibility Audit — monthly reports</div>
  <p class="hint" style="margin-bottom:12px;">One report per month from the client's start date (PDF or HTML). These are listed on the client's dashboard under AI Visibility.</p>
  <form method="post" action="/api/upload-audit" enctype="multipart/form-data" class="card gated" style="display:flex;gap:12px;align-items:end;flex-wrap:wrap;margin-bottom:14px;">
    <input type="hidden" name="client_id" value={clientId} />
    <div><label>Month</label><input type="month" name="period" required /></div>
    <div style="flex:1;min-width:220px;"><label>Report file (PDF or HTML)</label><input type="file" name="file" accept=".pdf,.html,.htm" required /></div>
    <button class="btn" type="submit">Upload report</button>
  </form>
  {audits.length > 0 && (
    <div class="tbl-wrap" style="margin-bottom:10px;">
      <table class="tbl" style="min-width:0;">
        <thead><tr><th>Month</th><th>Title</th><th></th></tr></thead>
        <tbody>
          {audits.map((a) => (
            <tr>
              <td>{monthName(a.period)}</td>
              <td>{a.title}</td>
              <td style="white-space:nowrap;text-align:right;">
                <a href={`/report/${a.id}`} target="_blank" rel="noopener" class="mini">Open</a>
                <form method="post" action="/api/audit-delete" class="gated" style="display:inline;" onsubmit="return confirm('Remove this monthly report?');">
                  <input type="hidden" name="id" value={a.id} />
                  <input type="hidden" name="client_id" value={clientId} />
                  <button class="mini" type="submit" style="color:#ffb3b3;">Remove</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <script is:inline define:vars={{ pages, pipeline, openItems, isSuper }}>
    const mk = (html) => { const d = document.createElement('div'); d.className = 'erow'; d.innerHTML = html; return d; };
    const esc = (s) => (s == null ? '' : String(s)).replace(/"/g, '&quot;');
    const statusOpts = (sel) => ['Not Started','Drafting','For Review','Live'].map((o) => `<option${o===sel?' selected':''}>${o}</option>`).join('');
    const priOpts = (sel) => ['HIGH','MED','LOW'].map((o) => `<option${o===sel?' selected':''}>${o}</option>`).join('');

    function pagesRow(d){ d=d||{}; return mk(
      `<input data-f="page" placeholder="/page-url" value="${esc(d.page)}" style="flex:2;">
       <input data-f="clicks" placeholder="clicks" value="${esc(d.clicks)}" inputmode="numeric" style="flex:1;">
       <input data-f="impr" placeholder="impr" value="${esc(d.impr)}" inputmode="numeric" style="flex:1;">
       <button type="button" class="mini js-del">✕</button>`); }
    const SOP_STEPS = [
      'Live & correct (View Source)', 'Cluster wiring', 'In sitemap.xml',
      'Indexing requested', 'Schema validated', 'GEO / AI checks', 'Registered for tracking'
    ];
    const sopOpts = (sel) => [['pending','Pending'],['pass','Pass'],['na','N/A']]
      .map(([v,l]) => `<option value="${v}"${v===sel?' selected':''}>${l}</option>`).join('');
    function sopPanel(sop){
      sop = Array.isArray(sop) ? sop : [];
      return `<div class="sop-panel" hidden style="width:100%;background:rgba(0,0,0,0.22);border:1px solid var(--line);border-radius:10px;padding:12px 14px;display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:8px;">
        ${SOP_STEPS.map((s,i)=>`<label style="display:flex;justify-content:space-between;align-items:center;gap:8px;font-size:.8rem;font-weight:600;margin:0;">${i+1}. ${s}
          <select data-s="${i}" style="width:96px;padding:5px 7px;font-size:.78rem;">${sopOpts(sop[i]||'pending')}</select></label>`).join('')}
      </div>`;
    }
    function pipeRow(d){ d=d||{}; return mk(
      `<input data-f="num" placeholder="#" value="${esc(d.num)}" style="width:74px;" title="Unique post ID">
       <input data-f="post" placeholder="Post title" value="${esc(d.post)}" style="flex:2;">
       <select data-f="status" style="flex:1;">${statusOpts(d.status)}</select>
       <input data-f="published" type="date" value="${esc(d.published)}" style="flex:1;">
       <button type="button" class="mini js-sop" title="Post-publish SOP checklist">SOP</button>
       <button type="button" class="mini js-del">✕</button>
       ${sopPanel(d.sop)}`); }
    function oiRow(d){ d=d||{}; return mk(
      `<select data-f="pri" style="width:90px;">${priOpts(d.pri)}</select>
       <input data-f="text" placeholder="Deliverable / item" value="${esc(d.text)}" style="flex:1;">
       <button type="button" class="mini js-del">✕</button>`); }

    const lists = {
      pages: { el: document.getElementById('pagesList'), row: pagesRow, data: pages },
      pipe:  { el: document.getElementById('pipeList'),  row: pipeRow,  data: pipeline },
      oi:    { el: document.getElementById('oiList'),    row: oiRow,    data: openItems },
    };
    Object.values(lists).forEach((L) => (L.data || []).forEach((d) => L.el.appendChild(L.row(d))));
    document.querySelectorAll('.js-add').forEach((b) => b.addEventListener('click', () => {
      const L = lists[b.dataset.list]; L.el.appendChild(L.row({}));
    }));
    document.addEventListener('click', (e) => {
      const x = e.target.closest('.js-del'); if (x) { x.closest('.erow').remove(); return; }
      const s = e.target.closest('.js-sop');
      if (s) { const p = s.closest('.erow').querySelector('.sop-panel'); if (p) p.hidden = !p.hidden; }
    });

    const grab = (el) => { const o = {}; el.querySelectorAll('[data-f]').forEach((i) => o[i.dataset.f] = i.value); return o; };
    const collect = (el, mapper) => Array.from(el.querySelectorAll('.erow')).map((r) => mapper(grab(r)));

    // Serialize the dynamic lists on the main content form only.
    document.querySelector('form[action="/api/save-content"]').addEventListener('submit', () => {
      document.getElementById('f-pages').value = JSON.stringify(collect(lists.pages.el, (o) => ({ page:o.page, clicks:Number(o.clicks)||0, impr:Number(o.impr)||0 })).filter((x)=>x.page));
      document.getElementById('f-pipe').value = JSON.stringify(
        Array.from(lists.pipe.el.querySelectorAll('.erow')).map((r) => {
          const o = grab(r);
          const sop = Array.from(r.querySelectorAll('[data-s]')).map((s) => s.value);
          return { num:o.num, post:o.post, status:o.status, published:o.published, sop };
        }).filter((x)=>x.post||x.num));
      document.getElementById('f-oi').value    = JSON.stringify(collect(lists.oi.el, (o) => ({ pri:o.pri, text:o.text })).filter((x)=>x.text));
    });

    // Regular admins: every gated form (content save, audit upload/remove)
    // prompts for a note and goes to super-admin approval.
    if (!isSuper) {
      document.querySelectorAll('form.gated').forEach((f) => {
        f.addEventListener('submit', (e) => {
          const note = window.prompt('This change needs super-admin approval.\nAdd a short note describing your request:');
          if (note === null) { e.preventDefault(); return; }
          let inp = f.querySelector('input[name="reason"]');
          if (!inp) { inp = document.createElement('input'); inp.type='hidden'; inp.name='reason'; f.appendChild(inp); }
          inp.value = note;
        });
      });
    }
  </script>
</PortalLayout>
