---
import PortalLayout from '../layouts/PortalLayout.astro';
import { createSupabaseServer } from '../lib/supabase';

const { profile } = Astro.locals;
const isAdmin = profile?.role === 'admin' || profile?.role === 'super_admin';
const supabase = createSupabaseServer(Astro);

// Clients go straight to their living dashboard (served by /d, with a sign-out
// link injected). Admins get the client list below.
if (!isAdmin) {
  if (profile?.client_id) {
    const { data } = await supabase.from('clients').select('id').eq('id', profile.client_id).single();
    if (data) return Astro.redirect('/d');
  }
}

type Client = { id: string; name: string; gsc_updated_at: string | null };
let clients: Client[] = [];
if (isAdmin) {
  const { data } = await supabase.from('clients').select('id, name, gsc_updated_at').order('name');
  clients = (data as Client[]) ?? [];
}
---

<PortalLayout title="Dashboard · Robles Tech Portal">
  {
    isAdmin ? (
      <>
        <p class="eyebrow">Admin</p>
        <h1>Client dashboards</h1>
        <p class="lede">Preview any client's live dashboard, or manage clients and content.</p>
        <div style="margin-bottom:24px;"><a class="btn" href="/admin">Manage clients &amp; content →</a></div>
        {clients.length === 0 ? (
          <div class="empty">No clients yet. Add one in the admin panel.</div>
        ) : (
          <ul class="report-list">
            {clients.map((c) => (
              <li>
                <a class="report-row" href={`/d?client=${c.id}`} target="_blank" rel="noopener">
                  <span>
                    <span class="r-title">{c.name}</span>
                    <span class="r-period" style="display:block;">
                      {c.gsc_updated_at ? `GSC updated ${new Date(c.gsc_updated_at).toLocaleString()}` : 'No GSC pull yet'}
                    </span>
                  </span>
                  <span class="r-go">Open dashboard →</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </>
    ) : (
      <>
        <p class="eyebrow">Your Dashboard</p>
        <h1>Dashboard</h1>
        <div class="empty">Your dashboard isn't set up yet. Your Robles Tech account manager will enable it shortly.</div>
      </>
    )
  }
</PortalLayout>
