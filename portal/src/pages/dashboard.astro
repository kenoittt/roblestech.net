---
import PortalLayout from '../layouts/PortalLayout.astro';
import { createSupabaseServer } from '../lib/supabase';

const { user, profile } = Astro.locals;
const isAdmin = profile?.role === 'admin';

const supabase = createSupabaseServer(Astro);

// Client name for the greeting (RLS returns only the caller's own client).
let clientName = '';
if (!isAdmin && profile?.client_id) {
  const { data: client } = await supabase.from('clients').select('name').eq('id', profile.client_id).single();
  clientName = client?.name ?? '';
}

// Report history. RLS guarantees a client only ever gets their own rows.
type ReportRow = { id: string; title: string; period: string };
let reports: ReportRow[] = [];
if (!isAdmin) {
  const { data } = await supabase
    .from('reports')
    .select('id, title, period')
    .order('period', { ascending: false });
  reports = (data as ReportRow[]) ?? [];
}

const fmt = (period: string) =>
  new Date(period + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<PortalLayout title="Dashboard · Robles Tech Portal">
  {
    isAdmin ? (
      <>
        <p class="eyebrow">Admin</p>
        <h1>Welcome back</h1>
        <p class="lede">You're signed in as an RTC administrator.</p>
        <div class="card">
          <p style="margin:0 0 16px;">Create client accounts and upload monthly SEO reports from the admin panel.</p>
          <a class="btn" href="/admin">Open admin panel →</a>
        </div>
      </>
    ) : (
      <>
        <p class="eyebrow">Your SEO Reports</p>
        <h1>{clientName || 'Dashboard'}</h1>
        <p class="lede">Your monthly search performance reports, newest first. Click any month to open it.</p>

        {reports.length === 0 ? (
          <div class="empty">No reports yet. Your first report will appear here once it's published.</div>
        ) : (
          <ul class="report-list">
            {reports.map((r) => (
              <li>
                <a class="report-row" href={`/report/${r.id}`} target="_blank" rel="noopener">
                  <span>
                    <span class="r-title">{r.title}</span>
                    <span class="r-period" style="display:block;">{fmt(r.period)}</span>
                  </span>
                  <span class="r-go">View report →</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </>
    )
  }
</PortalLayout>
