# Copy to .env and fill in from your Supabase project settings (Project Settings → API).
# NEVER commit the real .env — it is gitignored.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
PUBLIC_SUPABASE_URL=

# "anon" public key — safe to expose to the browser; Row-Level Security protects data.
PUBLIC_SUPABASE_ANON_KEY=

# "service_role" secret key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
# Used only in admin endpoints (create client accounts) and to stream private report files.
SUPABASE_SERVICE_ROLE_KEY=
