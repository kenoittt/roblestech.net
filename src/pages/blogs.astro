---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blog — Robles Technologies Corp."
  description="Practical guides, tutorials, and insights on Smartsheet, automation, AI, and technical consulting from the Robles Technologies Corp. team."
  active=""
>
  <Fragment slot="head">
    <style>
      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        margin-top: 48px;
      }
      .blog-card {
        background: var(--white);
        border-radius: 16px;
        overflow: hidden;
        border: 1.5px solid rgba(3,44,124,0.06);
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
      }
      .blog-card:hover {
        box-shadow: 0 16px 48px rgba(3,44,124,0.12);
        transform: translateY(-4px);
        border-color: rgba(4,100,221,0.15);
      }
      .blog-card-top {
        background: linear-gradient(135deg, var(--navy) 0%, var(--steel) 100%);
        padding: 28px 24px 20px;
        min-height: 120px;
        position: relative;
        overflow: hidden;
      }
      .blog-card-top::after {
        content: '';
        position: absolute;
        bottom: -24px; right: -24px;
        width: 100px; height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
      }
      .blog-category {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--green);
        background: rgba(174,227,123,0.15);
        padding: 4px 10px;
        border-radius: 100px;
        margin-bottom: 10px;
      }
      .blog-card-title {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--white);
        line-height: 1.3;
        letter-spacing: -0.015em;
        position: relative;
        z-index: 1;
      }
      .blog-card-body {
        padding: 20px 24px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .blog-excerpt {
        font-size: 0.82rem;
        color: var(--steel);
        line-height: 1.7;
        flex: 1;
        margin-bottom: 16px;
      }
      .blog-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .blog-read-more {
        color: var(--core-blue);
        font-weight: 700;
      }
      @media (max-width: 980px) {
        .blog-grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 600px) {
        .blog-card-top { min-height: 100px; padding: 20px 18px 16px; }
        .blog-card-title { font-size: 0.88rem; }
        .blog-card-body { padding: 16px 18px 20px; }
      }
    </style>
  </Fragment>

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="page-hero-pat"></div>
    <div class="breadcrumb"><a href="/">Home</a><span>/</span>Blog</div>
    <span class="sec-tag">Insights &amp; Guides</span>
    <h1 class="sec-h">The RTC Blog</h1>
    <p class="sec-p">Practical guides on Smartsheet, automation, AI, and technical consulting — written by the people who build it every day.</p>
  </div>

  <!-- BLOG LISTING -->
  <section class="sec" style="background:var(--off-white);">
    <div class="blog-grid">

      <a href="/smartsheet-vendor-data-without-sheet-access" class="blog-card rv">
        <div class="blog-card-top">
          <span class="blog-category">Smartsheet</span>
          <div class="blog-card-title">How to Let Subcontractors &amp; Vendors Submit Data to Smartsheet Without Giving Them Sheet Access</div>
        </div>
        <div class="blog-card-body">
          <p class="blog-excerpt">Need outside vendors or subcontractors to submit data into Smartsheet without seeing the whole sheet? Here's the exact Form + Dynamic View setup, step by step.</p>
          <div class="blog-meta">
            <span>Smartsheet · Forms · Dynamic View</span>
            <span class="blog-read-more">Read →</span>
          </div>
        </div>
      </a>

      <a href="/smartsheet-automate-onboarding-workflows" class="blog-card rv d1">
        <div class="blog-card-top" style="background:linear-gradient(135deg,#0464DD 0%,#2F58A3 100%);">
          <span class="blog-category">Automation</span>
          <div class="blog-card-title">How to Replace Manual Onboarding Spreadsheets with Automated Smartsheet Workflows</div>
        </div>
        <div class="blog-card-body">
          <p class="blog-excerpt">Still managing employee onboarding in Excel? Here's how to automate it in Smartsheet using Forms, automation rules, Reports, and a live Dashboard — so nothing slips.</p>
          <div class="blog-meta">
            <span>Smartsheet · Automation · Operations</span>
            <span class="blog-read-more">Read →</span>
          </div>
        </div>
      </a>

      <a href="/smartsheet-field-team-photo-attachments" class="blog-card rv d2">
        <div class="blog-card-top" style="background:linear-gradient(135deg,#3992FF 0%,#032C7C 100%);">
          <span class="blog-category">Field Operations</span>
          <div class="blog-card-title">How Field Teams Can Submit Photos &amp; Attachments to Smartsheet Without Sheet Access</div>
        </div>
        <div class="blog-card-body">
          <p class="blog-excerpt">Let field crews submit completion photos from their phones directly into Smartsheet — no license, no sheet access, no app install required. Just a form and a QR code.</p>
          <div class="blog-meta">
            <span>Smartsheet · Forms · Field Ops</span>
            <span class="blog-read-more">Read →</span>
          </div>
        </div>
      </a>

    </div>
  </section>
</BaseLayout>
