---
interface Props { title?: string; showNav?: boolean }
const { title = 'WanderWise', showNav = true } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0F766E" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="stylesheet" href="/app.css" />
  </head>
  <body>
    {showNav && (
      <header class="nav">
        <a class="brand" href={user ? '/trips' : '/'}>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M16.2 7.8l-2 6.3-6.4 2.1 2-6.3z"/></svg>
          Wander<span>Wise</span>
        </a>
        {user ? (
          <nav class="nav-links">
            <a href="/explore">Explore</a>
            <a href="/trips">Trips</a>
            <a href="/account">Account</a>
            <form method="post" action="/logout" class="m0"><button class="btn-ghost" type="submit">Sign out</button></form>
          </nav>
        ) : (
          <nav class="nav-links">
            <a href="/explore">Explore</a>
            <a href="/login">Sign in</a>
            <a href="/signup" class="btn-sm">Get started</a>
          </nav>
        )}
      </header>
    )}
    <main class="main"><slot /></main>
    <footer class="foot">WanderWise · plan smart, travel light</footer>
  </body>
</html>
