---
import { createSupabaseServer } from '../lib/supabase';
interface Props { title?: string; showNav?: boolean }
const { title = 'WanderWise', showNav = true } = Astro.props;
const user = Astro.locals.user;

// Unread notification count for the bell badge (0 if the table isn't there yet).
let unread = 0;
if (user) {
  try {
    const supabase = createSupabaseServer(Astro);
    const { count } = await supabase.from('notifications')
      .select('id', { count: 'exact', head: true }).eq('read', false);
    unread = count ?? 0;
  } catch { unread = 0; }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0F766E" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="stylesheet" href="/app.css" />
  </head>
  <body>
    {showNav && (
      <header class="nav">
        <a class="brand" href={user ? '/trips' : '/'}>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M16.2 7.8l-2 6.3-6.4 2.1 2-6.3z"/></svg>
          Wander<span>Wise</span>
        </a>
        {user && (
          <a class="bell" href="/notifications" aria-label={unread > 0 ? `Notifications (${unread} unread)` : 'Notifications'}>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
            {unread > 0 && <span class="bell-badge">{unread > 9 ? '9+' : unread}</span>}
          </a>
        )}
        <input type="checkbox" id="nav-open" class="nav-open" aria-label="Toggle menu" />
        <label for="nav-open" class="burger">
          <svg class="i-menu" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          <svg class="i-close" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
          <span class="vh" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);">Menu</span>
        </label>
        {user ? (
          <nav class="nav-links">
            <a href="/explore">Explore</a>
            <a href="/guides">Guides</a>
            <a href="/trips">Trips</a>
            <a href="/checklists">Checklists</a>
            <a href="/account">Account</a>
            <form method="post" action="/logout" class="m0"><button class="btn-ghost" type="submit">Sign out</button></form>
          </nav>
        ) : (
          <nav class="nav-links">
            <a href="/explore">Explore</a>
            <a href="/guides">Guides</a>
            <a href="/login">Sign in</a>
            <a href="/signup" class="btn-sm">Get started</a>
          </nav>
        )}
      </header>
    )}
    <main class="main"><slot /></main>
    <footer class="foot">WanderWise · plan smart, travel light</footer>
  </body>
</html>
