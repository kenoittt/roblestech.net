---
import AppLayout from '../../layouts/AppLayout.astro';
import { createSupabaseServer } from '../../lib/supabase';
import { getMonthProfile } from '../../lib/insights';
import { entryFor } from '../../lib/visa';
import Icon from '../../components/Icon.astro';

const { id } = Astro.params;
const supabase = createSupabaseServer(Astro);
const { data: dest } = await supabase.from('destinations').select('id,name,country,lat,lng').eq('id', id).single();
if (!dest) return Astro.redirect('/explore');

const month = Math.min(12, Math.max(1, Number(Astro.url.searchParams.get('m')) || new Date().getMonth() + 1));
const profile = await getMonthProfile(dest as any, month);

const { data: wl } = await supabase.from('wishlists').select('destination_id').eq('destination_id', id).maybeSingle();
const wished = !!wl;

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const w = profile?.weather_json ?? {};
const attire = profile?.attire_json ?? {};
const best = profile?.best_time_json ?? {};
const festivals: any[] = profile?.festivals_json ?? [];
const gems: any[] = profile?.hidden_gems_json ?? [];
const topPlaces: any[] = best?.top_places ?? [];
const adventures: any[] = best?.adventures ?? [];
const hero = profile?.hero_image_url ?? null;

let passport: string | null = null;
if (Astro.locals.user) {
  const { data: prof } = await supabase.from('profiles').select('passport_country').eq('id', Astro.locals.user.id).maybeSingle();
  passport = (prof as any)?.passport_country ?? null;
}
const entry = entryFor(passport, dest.country);
const mapsUrl = (place: string) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(place + ', ' + dest.name + ', ' + dest.country)}`;
// Route to the best source for the place — official sites, guides, reviews —
// rather than assuming Wikipedia has it.
const infoUrl = (place: string) => `https://www.google.com/search?q=${encodeURIComponent(place + ' ' + dest.name + ' ' + dest.country)}`;
const wikiUrl = (place: string) => `https://en.wikipedia.org/wiki/Special:Search?search=${encodeURIComponent(place + ' ' + dest.name)}`;
const crowdDot: Record<string, string> = { peak: '#C0392B', shoulder: '#E0930B', 'off-season': '#177E4D' };
const crowdText: Record<string, string> = { peak: 'Peak season', shoulder: 'Shoulder season', 'off-season': 'Off-season (local feel)' };
---

<AppLayout title={`${dest.name} in ${MONTHS[month - 1]} · WanderWise`}>
  <p class="eyebrow">{dest.country}</p>
  <h1 style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">{dest.name}
    <form method="post" action="/api/wishlist-toggle" class="m0">
      <input type="hidden" name="destination_id" value={dest.id} />
      <input type="hidden" name="back" value={`/explore/${dest.id}?m=${month}`} />
      <button class="mini" type="submit">{wished ? <><Icon name="star" /> Saved</> : <><Icon name="star" /> Save to wishlist</>}</button>
    </form>
  </h1>

  <div class="tabbar" style="flex-wrap:wrap;width:100%;overflow-x:auto;">
    {MONTHS.map((m, i) => (
      <a href={`/explore/${dest.id}?m=${i + 1}`} class={month === i + 1 ? 'on' : ''}>{m}</a>
    ))}
  </div>

  {hero && <a href={hero} target="_blank" rel="noopener noreferrer" title="Open full-size photo">
    <img src={hero} alt={`${dest.name}`} loading="lazy"
      style="width:100%;height:220px;object-fit:cover;border-radius:16px;margin-bottom:14px;box-shadow:0 8px 24px rgba(28,43,43,.12);" />
  </a>}

  <div class="card" style="margin-bottom:14px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;border-left:4px solid var(--coral);">
    <div style="flex:1;min-width:200px;">
      <b style="display:inline-flex;align-items:center;gap:8px;"><Icon name="plane" /> Want to start a trip to {dest.name}?</b>
      <p class="hint" style="margin-top:2px;">One tap creates a trip project with {dest.name} as your first destination.</p>
    </div>
    {Astro.locals.user ? (
      <form method="post" action="/api/trip-create" class="m0">
        <input type="hidden" name="destination_name" value={dest.name} />
        <input type="hidden" name="pax" value="2" />
        <button class="btn btn-coral" type="submit">Start a trip</button>
      </form>
    ) : (
      <a class="btn btn-coral" href="/signup" style="text-decoration:none;">Sign up free to start</a>
    )}
  </div>

  <div class="card" style="margin-bottom:14px;">
    <h2>Weather in {MONTHS[month - 1]}</h2>
    {w.season && <p style="font-weight:800;color:var(--teal);margin:0 0 8px;display:flex;align-items:center;gap:7px;"><Icon name="calendar" /> Season: {w.season}</p>}
    {w.avg_high != null ? (
      <div class="cat-chips" style="margin:0 0 10px;">
        <span class="chip">High <b>{w.avg_high}°C</b></span>
        <span class="chip">Low <b>{w.avg_low}°C</b></span>
        <span class="chip">Rainy days <b>{w.rain_days}</b></span>
        <span class="chip">Humidity <b>{w.humidity}%</b></span>
      </div>
    ) : <p class="hint">Weather data unavailable right now.</p>}
    {w.climate_summary && <p>{w.climate_summary}</p>}
    {w.crowd_note && <p class="hint" style="margin-top:6px;">{w.crowd_note}</p>}
    {profile?.crowd_index && <p style="margin-top:8px;font-weight:700;display:flex;align-items:center;gap:8px;"><span style={`width:11px;height:11px;border-radius:50%;flex:0 0 auto;background:${crowdDot[profile.crowd_index]};`}></span>{crowdText[profile.crowd_index]}</p>}
  </div>

  {attire?.summary && (
    <div class="card" style="margin-bottom:14px;">
      <h2><Icon name="bag" /> What to wear &amp; pack</h2>
      <p>{attire.summary}</p>
      {Array.isArray(attire.items) && attire.items.length > 0 && (
        <div class="cat-chips" style="margin:10px 0 0;">{attire.items.map((i: string) => <span class="chip">{i}</span>)}</div>
      )}
    </div>
  )}

  {festivals.length > 0 && (
    <div class="card" style="margin-bottom:14px;">
      <h2><Icon name="ticket" /> Festivals &amp; events this month</h2>
      <div class="stack">
        {festivals.map((f: any) => <div><b>{f.name}</b> <span class="hint">— {f.timing}</span><br /><span style="font-size:.9rem;">{f.note}</span></div>)}
      </div>
    </div>
  )}

  {best?.verdict && (
    <div class="card" style="margin-bottom:14px;border-left:4px solid var(--coral);">
      <h2>Best time to go</h2>
      <p><b>{best.verdict}</b></p>
      {Array.isArray(best.best_months) && <p class="hint" style="margin-top:6px;">Best months: {best.best_months.join(', ')} — {best.reason}</p>}
    </div>
  )}

  {entry && (
    <div class="card" style={`margin-bottom:14px;border-left:4px solid ${entry.status === 'visa-free' ? 'var(--ok)' : entry.status === 'action-needed' ? 'var(--coral)' : 'var(--sun)'};`}>
      <h2><Icon name="passport" /> Visas &amp; entry</h2>
      <p style="font-weight:800;margin:0 0 6px;display:flex;align-items:center;gap:7px;"><Icon name={entry.status === 'visa-free' ? 'check' : entry.status === 'action-needed' ? 'passport' : 'alert'} /> {entry.headline}</p>
      <p style="margin:0 0 8px;">{entry.detail}</p>
      {entry.status === 'unknown' && (
        <p style="margin:0 0 8px;">{Astro.locals.user
          ? <a href="/account">Set your passport country →</a>
          : <a href="/signup">Create a free account with your passport country for personalized checks →</a>}</p>
      )}
      {entry.notes.map((n: string) => <p class="hint" style="margin:0 0 4px;">• {n}</p>)}
      <p style="margin:8px 0 0;font-size:.85rem;">
        {entry.official.map((o: any, i: number) => (
          <>{i > 0 && ' · '}<a href={o.url} target="_blank" rel="noopener noreferrer">{o.label} ↗</a></>
        ))}
      </p>
      <p class="hint" style="margin-top:8px;">Guidance checked {entry.checked}. Rules change — always confirm on the official government site before booking. Not legal advice.</p>
    </div>
  )}

  {topPlaces.length > 0 && (
    <div class="card" style="margin-bottom:14px;">
      <h2><Icon name="pin" /> Top places to visit</h2>
      <p class="hint" style="margin:0 0 10px;">Tap a place for map & background links.</p>
      <div class="stack">{topPlaces.map((p: any) => (
        <details class="place-det">
          <summary class="place-row">
            {p.img ? <a class="imglink" href={p.img} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" title="Open full-size photo"><img src={p.img} alt={p.name} loading="lazy" /></a> : <div class="ph"><Icon name="pin" /></div>}
            <div><b>{p.name}</b><div class="hint">{p.why}</div></div>
          </summary>
          <div class="place-actions">
            <a class="mini" href={infoUrl(p.name)} target="_blank" rel="noopener noreferrer">Best guides &amp; official info</a>
            <a class="mini" href={mapsUrl(p.name)} target="_blank" rel="noopener noreferrer">Google Maps</a>
            <a class="mini" href={wikiUrl(p.name)} target="_blank" rel="noopener noreferrer">Wikipedia</a>
          </div>
        </details>
      ))}</div>
    </div>
  )}

  {adventures.length > 0 && (
    <div class="card" style="margin-bottom:14px;">
      <h2><Icon name="mountain" /> Adventures nearby</h2>
      <p class="hint" style="margin:0 0 10px;">Hikes, mountains and outdoor days within reach — tap for details.</p>
      <div class="stack">{adventures.map((p: any) => (
        <details class="place-det">
          <summary class="place-row">
            {p.img ? <a class="imglink" href={p.img} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" title="Open full-size photo"><img src={p.img} alt={p.name} loading="lazy" /></a> : <div class="ph"><Icon name="mountain" /></div>}
            <div><b>{p.name}</b><div class="hint">{p.why}</div></div>
          </summary>
          <div class="place-actions">
            <a class="mini" href={infoUrl(p.name)} target="_blank" rel="noopener noreferrer">Best guides &amp; official info</a>
            <a class="mini" href={mapsUrl(p.name)} target="_blank" rel="noopener noreferrer">Google Maps</a>
            <a class="mini" href={wikiUrl(p.name)} target="_blank" rel="noopener noreferrer">Wikipedia</a>
          </div>
        </details>
      ))}</div>
    </div>
  )}

  {gems.length > 0 && (
    <div class="card" style="margin-bottom:14px;">
      <h2><Icon name="gem" /> Hidden gems</h2>
      <div class="stack">{gems.map((p: any) => (
        <details class="place-det">
          <summary class="place-row">
            {p.img ? <a class="imglink" href={p.img} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" title="Open full-size photo"><img src={p.img} alt={p.name} loading="lazy" /></a> : <div class="ph"><Icon name="gem" /></div>}
            <div><b>{p.name}</b><div class="hint">{p.why}</div></div>
          </summary>
          <div class="place-actions">
            <a class="mini" href={infoUrl(p.name)} target="_blank" rel="noopener noreferrer">Best guides &amp; official info</a>
            <a class="mini" href={mapsUrl(p.name)} target="_blank" rel="noopener noreferrer">Google Maps</a>
            <a class="mini" href={wikiUrl(p.name)} target="_blank" rel="noopener noreferrer">Wikipedia</a>
          </div>
        </details>
      ))}</div>
    </div>
  )}

  <p class="hint">Weather numbers are live climate data; travel notes are curated by WanderWise; photos via Wikipedia/Wikimedia Commons. Verify dates locally — festival timing (especially lunar-calendar events) can shift year to year.</p>

  <style>
    .place-row{display:flex;gap:12px;align-items:center;}
    .place-row img,.place-row .ph{width:76px;height:56px;flex:0 0 76px;border-radius:10px;object-fit:cover;
      border:1px solid var(--glass-edge);box-shadow:0 2px 8px rgba(28,43,43,.10);}
    .place-row .imglink{flex:0 0 76px;line-height:0;}
    .place-row .ph{display:flex;align-items:center;justify-content:center;font-size:1.3rem;background:rgba(255,255,255,.45);}
    .place-det summary{cursor:pointer;list-style:none;border-radius:10px;padding:4px;}
    .place-det summary::-webkit-details-marker{display:none;}
    .place-det summary:hover{background:rgba(255,255,255,.45);}
    .place-det[open] summary{background:rgba(15,118,110,.06);}
    .place-actions{display:flex;gap:8px;flex-wrap:wrap;padding:10px 4px 4px 92px;}
    @media(max-width:480px){.place-actions{padding-left:4px;}}
  </style>
</AppLayout>
