---
import AppLayout from '../../layouts/AppLayout.astro';
import Icon from '../../components/Icon.astro';
import { createSupabaseServer, createSupabaseAdmin } from '../../lib/supabase';
import { destImage } from '../../lib/images';

const supabase = createSupabaseServer(Astro);
const q = (Astro.url.searchParams.get('q') ?? '').trim();
type Dest = { id: string; name: string; country: string; image_url?: string | null };
let query = supabase.from('destinations').select('*').eq('active', true).order('country').order('name');
if (q) query = query.or(`name.ilike.%${q}%,country.ilike.%${q}%`);
const { data } = await query;
const dests: Dest[] = (data as Dest[]) ?? [];

// Fill missing photos from Wikipedia once, then persist so future loads are instant.
const missing = dests.filter((d) => !d.image_url);
if (missing.length) {
  const admin = createSupabaseAdmin();
  await Promise.all(missing.map(async (d) => {
    const img = await destImage(d.name, d.country, 480);
    if (!img) return;
    d.image_url = img;
    await admin.from('destinations').update({ image_url: img }).eq('id', d.id); // no-op until migration adds the column
  }));
}

const byCountry: Record<string, Dest[]> = {};
for (const d of dests) (byCountry[d.country] ??= []).push(d);
const month = new Date().getMonth() + 1;
const mapData = dests.map((d: any) => ({ id: d.id, name: d.name, country: d.country, lat: d.lat, lng: d.lng, image_url: d.image_url ?? null, month }));
---
<AppLayout title="Explore · WanderWise">
  <p class="eyebrow">Monthly Destination Explorer</p>
  <h1>Where next — and <em style="color:var(--teal);font-style:normal;">when</em>?</h1>
  <p class="lede">Pick a destination to see what it's like month by month.</p>

  <form method="get" class="rowflex" style="margin-bottom:18px;">
    <div style="flex:1;min-width:200px;"><input name="q" value={q} placeholder="Search: Hong Kong, Samarkand, Taipei…" /></div>
    <button class="btn" type="submit">Search</button>
  </form>

  {q && dests.length === 0 && (
    <div class="card" style="text-align:center;">
      <h2>“{q}” isn't covered yet</h2>
      <p class="hint">Launch coverage is Vietnam, Taiwan, Hong Kong, Kazakhstan, Uzbekistan, and Kyrgyzstan — worldwide is coming. Check back soon!</p>
    </div>
  )}

  <div class="card" style="margin-bottom:8px;">
    <h2><Icon name="map" /> Map view</h2>
    <div id="explore-map" style="height:44vh;border-radius:14px;border:1px solid var(--line);"></div>
    <p class="hint" style="margin-top:6px;">Tap a pin to open that city's month-by-month profile.</p>
  </div>

  {Object.entries(byCountry).map(([country, list]) => (
    <div class="section">
      <div class="country-head">
        {list.find((d) => d.image_url)?.image_url && (
          <img src={list.find((d) => d.image_url)!.image_url!} alt={country} loading="lazy" />
        )}
        <h2>{country}</h2>
      </div>
      <div class="dest-grid">
        {list.map((d) => (
          <a class="dest-card" href={`/explore/${d.id}?m=${month}`}>
            {d.image_url
              ? <img src={d.image_url} alt={d.name} loading="lazy" />
              : <div class="dest-ph"><Icon name="globe" size={28} /></div>}
            <div class="dest-label"><b>{d.name}</b><span>12-month profile →</span></div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <p class="hint" style="margin-top:20px;">Photos via Wikipedia/Wikimedia Commons.</p>

  <script type="application/json" id="explore-map-data" set:html={JSON.stringify(mapData)} />
  <script src="../../scripts/explore-map.js"></script>

  <style>
    .country-head{display:flex;align-items:center;gap:12px;margin-bottom:4px;}
    .country-head img{width:104px;height:56px;object-fit:cover;border-radius:12px;border:1px solid var(--glass-edge);box-shadow:0 2px 10px rgba(28,43,43,.12);}
    .country-head h2{margin:0;}
  </style>
  <style>
    .dest-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-top:8px;}
    .dest-card{display:block;border-radius:16px;overflow:hidden;text-decoration:none;color:var(--ink);
      background:var(--glass);backdrop-filter:blur(16px) saturate(1.4);-webkit-backdrop-filter:blur(16px) saturate(1.4);
      border:1px solid var(--glass-edge);box-shadow:0 8px 24px rgba(28,43,43,.08);}
    .dest-card:active{transform:scale(.99);}
    .dest-card img,.dest-ph{width:100%;height:120px;object-fit:cover;display:block;}
    .dest-ph{display:flex;align-items:center;justify-content:center;font-size:2rem;background:rgba(15,118,110,.10);}
    .dest-label{padding:10px 12px;display:flex;flex-direction:column;gap:2px;}
    .dest-label span{color:var(--muted);font-size:.78rem;}
  </style>
</AppLayout>
