---
import AppLayout from '../../../layouts/AppLayout.astro';
import { createSupabaseServer, createSupabaseAdmin } from '../../../lib/supabase';
import { entryFor } from '../../../lib/visa';
import { CURRENCIES } from '../../../lib/currencies';
import Icon from '../../../components/Icon.astro';

const { id } = Astro.params;
const supabase = createSupabaseServer(Astro);
const { data: trip } = await supabase.from('trips')
  .select('id,name,start_date,end_date,pax,base_currency,status,owner_id').eq('id', id).single();
if (!trip) return Astro.redirect('/trips?err=' + encodeURIComponent('Trip not found.'));

type Leg = { id: string; destination_name: string; arrival_airport: string | null; departure_airport: string | null; airline?: string | null; flight_no?: string | null; start_date: string | null; end_date: string | null };
type Lodging = { id: string; name: string; address: string | null; check_in_at: string | null; check_out_at: string | null; confirmation_ref: string | null; booking_url?: string | null };
const [{ data: legsData }, { data: lodgingData }, { data: checklistData }] = await Promise.all([
  supabase.from('trip_legs').select('*').eq('trip_id', id).order('position'),
  supabase.from('lodgings').select('*').eq('trip_id', id).order('check_in_at'),
  supabase.from('trip_checklist').select('id,item,done').eq('trip_id', id).order('position').order('created_at'),
]);
const legs: Leg[] = (legsData as Leg[]) ?? [];
const lodgings: Lodging[] = (lodgingData as Lodging[]) ?? [];
const checklist = (checklistData ?? []) as { id: string; item: string; done: boolean }[];
const isOwner = trip.owner_id === Astro.locals.user?.id;

// Sharing: membership rows come through RLS; names/emails resolved via admin
// (profiles are self-read-only under RLS, so members can still see who's on).
const { data: memberRows } = await supabase.from('trip_members')
  .select('user_id,role,created_at').eq('trip_id', id).order('created_at');
const memberIds = [trip.owner_id, ...(memberRows ?? []).map((m: any) => m.user_id)];
const admin = createSupabaseAdmin();
const { data: profs } = await admin.from('profiles').select('id,display_name,email').in('id', memberIds);
const who = (uid: string) => {
  const p = (profs ?? []).find((x: any) => x.id === uid);
  return { name: p?.display_name || 'Traveler', email: p?.email || '' };
};
const members = (memberRows ?? []).map((m: any) => ({ ...m, ...who(m.user_id) }));
const owner = who(trip.owner_id);
const isMember = members.some((m: any) => m.user_id === Astro.locals.user?.id);

// Destination dropdown + entry requirements for the trip's countries.
const { data: destRows } = await supabase.from('destinations').select('name,country').eq('active', true).order('country').order('name');
const destList = (destRows ?? []) as { name: string; country: string }[];
const destByCountry: Record<string, string[]> = {};
for (const d of destList) (destByCountry[d.country] ??= []).push(d.name);
const { data: myProfile } = await supabase.from('profiles').select('passport_country').eq('id', Astro.locals.user?.id).maybeSingle();
const passport = (myProfile as any)?.passport_country ?? null;

const norm = (s: string) => s.trim().toLowerCase();
const legCountries = [...new Set(legs.map((l) => {
  const ln = norm(l.destination_name);
  const hit = destList.find((d) => { const dn = norm(d.name); return dn === ln || ln.includes(dn) || dn.includes(ln) || ln === norm(d.country); });
  return hit?.country ?? null;
}).filter(Boolean))] as string[];
const entryCards = legCountries.map((c) => entryFor(passport, c)).filter(Boolean);

const ok = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');
const fmtDT = (s: string | null) => (s ? new Date(s).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }) : '—');
const flightStatusUrl = (fno: string) => `https://www.flightaware.com/live/flight/${encodeURIComponent(fno)}`;
const currencyKnown = CURRENCIES.some((c) => c.code === trip.base_currency);
---

<AppLayout title={`${trip.name} · WanderWise`}>
  <p class="eyebrow">Trip Project</p>
  <h1>{trip.name} <span class={`pill ${trip.status}`}>{trip.status}</span></h1>
  <div class="tabbar">
    <a href={`/trips/${id}`} class="on">Details</a>
    <a href={`/trips/${id}/itinerary`}>Itinerary</a>
    <a href={`/trips/${id}/map`}>Map</a>
    <a href={`/trips/${id}/budget`}>Budget</a>
    <a href={`/trips/${id}/today`}>Today</a>
  </div>
  {ok && <div class="alert alert-ok">{decodeURIComponent(ok)}</div>}
  {err && <div class="alert alert-error">{decodeURIComponent(err)}</div>}

  <details class="edit-block card">
    <summary>
      <div class="read">
        <b>Trip settings</b>
        <span class="hint" style="display:inline-flex;align-items:center;gap:6px;flex-wrap:wrap;"><Icon name="calendar" size={13} /> {trip.start_date ?? 'no dates'}{trip.end_date ? ' → ' + trip.end_date : ''} · <Icon name="users" size={13} /> {trip.pax} pax · <Icon name="wallet" size={13} /> {trip.base_currency}</span>
      </div>
      <span class="row-toggle" data-closed="Edit" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
    </summary>
    <form method="post" action="/api/trip-update" class="stack" style="margin-top:14px;">
      <input type="hidden" name="id" value={trip.id} />
      <div class="grid2">
        <div><label>Trip name</label><input name="name" value={trip.name} required placeholder="Put the name of your trip" /></div>
        <div><label>Pax (travelers)</label><input name="pax" type="number" min="1" value={trip.pax} /></div>
        <div><label>Start date</label><input name="start_date" type="date" value={trip.start_date ?? ''} /></div>
        <div><label>End date</label><input name="end_date" type="date" value={trip.end_date ?? ''} /></div>
        <div><label>Currency</label>
          <select name="base_currency">
            {!currencyKnown && <option value={trip.base_currency} selected>{trip.base_currency}</option>}
            {CURRENCIES.map((c) => <option value={c.code} selected={trip.base_currency === c.code}>{c.sym} · {c.code} — {c.name}</option>)}
          </select>
        </div>
        <div><label>Status</label>
          <select name="status">
            <option value="planning" selected={trip.status === 'planning'}>Planning</option>
            <option value="active" selected={trip.status === 'active'}>Active (on the trip)</option>
            <option value="archived" selected={trip.status === 'archived'}>Archived</option>
          </select>
        </div>
      </div>
      <div class="rowflex"><button class="btn" type="submit">Save trip</button></div>
      <p class="hint">Changing pax instantly recalculates every budget row from its entry side (group or per-person).</p>
    </form>
  </details>

  <div class="section">
    <h2><Icon name="plane" /> Destinations &amp; flights</h2>
    <div class="stack">
      {legs.map((l) => (
        <details class="edit-block card">
          <summary>
            <div class="read">
              <b>{l.destination_name}</b>
              <span class="hint">
                {(l.airline || l.flight_no) ? [l.airline, l.flight_no].filter(Boolean).join(' ') : 'No flight yet'}
                {l.arrival_airport ? ` · → ${l.arrival_airport}` : ''}
                {l.start_date ? ` · ${l.start_date}` : ''}
              </span>
              {l.flight_no && <a class="mini" style="margin-left:8px;" href={flightStatusUrl(l.flight_no)} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">Live flight status →</a>}
            </div>
            <span class="row-toggle" data-closed="Edit" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
          </summary>
          <form method="post" action="/api/leg-save" class="rowflex" style="margin-top:14px;">
            <input type="hidden" name="id" value={l.id} />
            <input type="hidden" name="trip_id" value={trip.id} />
            <div style="flex:2;min-width:170px;"><label>Destination</label>
              <select name="destination_name" required>
                {!destList.some((d) => d.name === l.destination_name) && <option value={l.destination_name} selected>{l.destination_name}</option>}
                {Object.entries(destByCountry).map(([country, names]) => (
                  <optgroup label={country}>{names.map((n) => <option value={n} selected={n === l.destination_name}>{n}</option>)}</optgroup>
                ))}
              </select>
            </div>
            <div style="width:130px;"><label>Airline</label><input name="airline" value={l.airline ?? ''} placeholder="Cebu Pacific" /></div>
            <div style="width:110px;"><label>Flight #</label><input name="flight_no" value={l.flight_no ?? ''} placeholder="5J310" /></div>
            <div style="width:100px;"><label>Arrive</label><input name="arrival_airport" value={l.arrival_airport ?? ''} placeholder="HKG" /></div>
            <div style="width:100px;"><label>Depart</label><input name="departure_airport" value={l.departure_airport ?? ''} placeholder="TPE" /></div>
            <div style="width:150px;"><label>From</label><input name="start_date" type="date" value={l.start_date ?? ''} /></div>
            <div style="width:150px;"><label>To</label><input name="end_date" type="date" value={l.end_date ?? ''} /></div>
            <button class="mini" type="submit">Save</button>
            <button class="mini" type="submit" name="op" value="delete" style="color:var(--bad);" onclick="return confirm('Remove this destination?');" aria-label="Remove destination">✕</button>
          </form>
        </details>
      ))}
      <details class="edit-block card" style="border-style:dashed;">
        <summary>
          <div class="read"><b>＋ Add a destination</b><span class="hint">Pick a city, add your flight — live status links automatically</span></div>
          <span class="row-toggle" data-closed="Add" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
        </summary>
        <form method="post" action="/api/leg-save" class="rowflex" style="margin-top:14px;">
          <input type="hidden" name="trip_id" value={trip.id} />
          <div style="flex:2;min-width:170px;"><label>Destination</label>
            <select name="destination_name" required>
              <option value="" disabled selected>Choose a city…</option>
              {Object.entries(destByCountry).map(([country, names]) => (
                <optgroup label={country}>{names.map((n) => <option value={n}>{n}</option>)}</optgroup>
              ))}
            </select>
          </div>
          <div style="width:130px;"><label>Airline</label><input name="airline" placeholder="Cebu Pacific" /></div>
          <div style="width:110px;"><label>Flight #</label><input name="flight_no" placeholder="5J310" /></div>
          <div style="width:100px;"><label>Arrive</label><input name="arrival_airport" placeholder="HKG" /></div>
          <button class="btn" type="submit" style="padding:10px 16px;">Add</button>
        </form>
      </details>
    </div>
  </div>

  {entryCards.length > 0 && (
    <div class="section">
      <h2><Icon name="passport" /> Visas &amp; entry requirements</h2>
      <div class="stack">
        {entryCards.map((v: any) => (
          <div class="card" style={`border-left:4px solid ${v.status === 'visa-free' ? 'var(--ok)' : v.status === 'action-needed' ? 'var(--coral)' : 'var(--sun)'};`}>
            <p style="font-weight:800;margin:0 0 6px;display:flex;align-items:center;gap:7px;">
              <Icon name={v.status === 'visa-free' ? 'check' : v.status === 'action-needed' ? 'passport' : 'alert'} /> {v.headline}
            </p>
            <p style="margin:0 0 8px;">{v.detail}</p>
            {v.status === 'unknown' && <p style="margin:0 0 8px;"><a href="/account">Set passport country →</a></p>}
            {v.notes.map((n: string) => <p class="hint" style="margin:0 0 4px;">• {n}</p>)}
            <p style="margin:8px 0 0;font-size:.85rem;overflow-wrap:anywhere;">
              {v.official.map((o: any, i: number) => (
                <>{i > 0 && ' · '}<a href={o.url} target="_blank" rel="noopener noreferrer">{o.label} ↗</a></>
              ))}
            </p>
            <p class="hint" style="margin-top:8px;">Guidance checked {v.checked}. Rules change — always confirm on the official site before booking. Not legal advice.</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="section">
    <h2><Icon name="bed" /> Lodging</h2>
    <div class="stack">
      {lodgings.map((g) => (
        <details class="edit-block card">
          <summary>
            <div class="read">
              <b>{g.name}</b>
              <span class="hint">{fmtDT(g.check_in_at)} → {fmtDT(g.check_out_at)}{g.address ? ` · ${g.address}` : ''}</span>
              {g.booking_url && <a class="mini" style="margin-left:8px;" href={g.booking_url} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">Open booking →</a>}
            </div>
            <span class="row-toggle" data-closed="Edit" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
          </summary>
          <form method="post" action="/api/lodging-save" class="stack" style="margin-top:14px;">
            <input type="hidden" name="id" value={g.id} />
            <input type="hidden" name="trip_id" value={trip.id} />
            <div class="grid2">
              <div><label>Name</label><input name="name" value={g.name} required /></div>
              <div><label>Confirmation #</label><input name="confirmation_ref" value={g.confirmation_ref ?? ''} /></div>
              <div style="grid-column:1/-1;"><label>Address</label><input name="address" value={g.address ?? ''} /></div>
              <div style="grid-column:1/-1;"><label>Booking link (Trip.com, Airbnb, Agoda, airline ticket…)</label>
                <input name="booking_url" type="url" value={g.booking_url ?? ''} placeholder="https://www.trip.com/…" /></div>
              <div><label>Check-in</label><input name="check_in_at" type="datetime-local" value={g.check_in_at ? g.check_in_at.slice(0, 16) : ''} /></div>
              <div><label>Check-out</label><input name="check_out_at" type="datetime-local" value={g.check_out_at ? g.check_out_at.slice(0, 16) : ''} /></div>
            </div>
            <div class="rowflex">
              <button class="mini" type="submit">Save</button>
              <button class="mini" type="submit" name="op" value="delete" style="color:var(--bad);" onclick="return confirm('Remove this lodging?');">Remove</button>
            </div>
          </form>
        </details>
      ))}
      <details class="edit-block card" style="border-style:dashed;">
        <summary>
          <div class="read"><b>＋ Add lodging</b><span class="hint">Hotel, Airbnb or any reservation — paste the booking link to open it anytime</span></div>
          <span class="row-toggle" data-closed="Add" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
        </summary>
        <form method="post" action="/api/lodging-save" class="rowflex" style="margin-top:14px;">
          <input type="hidden" name="trip_id" value={trip.id} />
          <div style="flex:1;min-width:180px;"><label>Name</label><input name="name" required placeholder="Harbour View Hotel" /></div>
          <div style="flex:1;min-width:200px;"><label>Booking link</label><input name="booking_url" type="url" placeholder="https://www.airbnb.com/…" /></div>
          <div style="width:170px;"><label>Check-in</label><input name="check_in_at" type="datetime-local" /></div>
          <div style="width:170px;"><label>Check-out</label><input name="check_out_at" type="datetime-local" /></div>
          <button class="btn" type="submit" style="padding:10px 16px;">Add</button>
        </form>
      </details>
    </div>
  </div>

  <div class="section" id="checklist">
    <h2><Icon name="bag" /> Travel checklist</h2>
    <div class="card stack">
      {checklist.map((c) => (
        <div class="rowflex" style="align-items:center;border-bottom:1px solid var(--line);padding-bottom:8px;">
          <form method="post" action="/api/checklist-save" class="m0">
            <input type="hidden" name="trip_id" value={trip.id} />
            <input type="hidden" name="id" value={c.id} />
            <input type="hidden" name="op" value="toggle" />
            <input type="hidden" name="done" value={c.done ? '0' : '1'} />
            <button type="submit" class="checkbox" aria-label={c.done ? 'Mark as not packed' : 'Mark as packed'}>
              {c.done ? (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4" fill="rgba(15,118,110,.14)"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>
              ) : (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4"/></svg>
              )}
            </button>
          </form>
          <span style={`flex:1;${c.done ? 'text-decoration:line-through;color:var(--muted);' : ''}`}>{c.item}</span>
          <form method="post" action="/api/checklist-save" class="m0">
            <input type="hidden" name="trip_id" value={trip.id} />
            <input type="hidden" name="id" value={c.id} />
            <input type="hidden" name="op" value="delete" />
            <button class="mini" type="submit" style="color:var(--bad);" aria-label="Delete item">✕</button>
          </form>
        </div>
      ))}
      {checklist.length === 0 && <p class="hint">Nothing yet — add what you don't want to forget: passport, chargers, meds, adapters…</p>}
      <form method="post" action="/api/checklist-save" class="rowflex">
        <input type="hidden" name="trip_id" value={trip.id} />
        <div style="flex:1;min-width:180px;"><label>Add an item</label><input name="item" required placeholder="Passport, power bank, sunscreen…" /></div>
        <button class="btn" type="submit" style="padding:11px 16px;">Add</button>
      </form>
      <p class="hint">Tip: the <a href={`/explore`}>Explore</a> page's "What to wear & pack" for your destination and month is a great starting list.</p>
    </div>
  </div>

  <div class="section">
    <h2><Icon name="share" /> Share this trip</h2>
    <div class="card stack">
      <div class="rowflex" style="align-items:center;">
        <span class="pill active">owner</span>
        <div style="flex:1;min-width:150px;"><b>{owner.name}</b> <span class="hint">{owner.email}</span></div>
      </div>
      {members.map((m: any) => (
        <div class="rowflex" style="align-items:center;border-top:1px solid var(--line);padding-top:10px;">
          <span class="pill planning">{m.role}</span>
          <div style="flex:1;min-width:150px;"><b>{m.name}</b> <span class="hint">{m.email}</span></div>
          {isOwner && (
            <form method="post" action="/api/member-save" class="m0 rowflex" style="gap:6px;">
              <input type="hidden" name="trip_id" value={trip.id} />
              <input type="hidden" name="user_id" value={m.user_id} />
              <select name="role" style="width:auto;padding:6px 8px;font-size:.8rem;">
                <option value="editor" selected={m.role === 'editor'}>editor</option>
                <option value="viewer" selected={m.role === 'viewer'}>viewer</option>
              </select>
              <button class="mini" type="submit" name="op" value="role">Save</button>
              <button class="mini" type="submit" name="op" value="remove" style="color:var(--bad);"
                onclick={`return confirm('Remove ${m.name} from this trip?');`} aria-label="Remove member">✕</button>
            </form>
          )}
        </div>
      ))}
      {members.length === 0 && <p class="hint">No one else yet — invite a travel buddy below.</p>}
      {isOwner ? (
        <form method="post" action="/api/member-save" class="rowflex" style="border-top:1px dashed var(--line);padding-top:12px;">
          <input type="hidden" name="trip_id" value={trip.id} />
          <input type="hidden" name="op" value="add" />
          <div style="flex:1;min-width:200px;"><label>Invite by email</label><input name="email" type="email" required placeholder="friend@example.com" /></div>
          <div style="width:150px;"><label>Role</label>
            <select name="role"><option value="editor">Editor (can edit)</option><option value="viewer">Viewer (read-only)</option></select>
          </div>
          <button class="btn" type="submit" style="padding:11px 16px;">Invite</button>
        </form>
      ) : (
        <p class="hint">Only the trip owner can invite or remove people.</p>
      )}
      <p class="hint">They need a free WanderWise account with that email. Editors can change everything except membership; viewers can only look.</p>
    </div>
  </div>

  <div class="section card">
    <h2>Trip actions</h2>
    <div class="rowflex">
      <form method="post" action="/api/trip-action" class="m0">
        <input type="hidden" name="id" value={trip.id} /><input type="hidden" name="op" value="duplicate" />
        <button class="mini" type="submit">Duplicate trip</button>
      </form>
      {isOwner && (
        <form method="post" action="/api/trip-action" class="m0" onsubmit="return confirm('Delete this trip and all its data? This cannot be undone.');">
          <input type="hidden" name="id" value={trip.id} /><input type="hidden" name="op" value="delete" />
          <button class="mini" type="submit" style="color:var(--bad);border-color:var(--bad);">Delete trip</button>
        </form>
      )}
      {!isOwner && isMember && (
        <form method="post" action="/api/member-save" class="m0" onsubmit="return confirm('Leave this trip? You will lose access until the owner invites you again.');">
          <input type="hidden" name="trip_id" value={trip.id} /><input type="hidden" name="op" value="leave" />
          <button class="mini" type="submit" style="color:var(--bad);border-color:var(--bad);">Leave trip</button>
        </form>
      )}
    </div>
  </div>
</AppLayout>
