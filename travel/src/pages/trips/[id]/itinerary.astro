---
import AppLayout from '../../../layouts/AppLayout.astro';
import Icon from '../../../components/Icon.astro';
import { createSupabaseServer } from '../../../lib/supabase';

const { id } = Astro.params;
const supabase = createSupabaseServer(Astro);
const { data: trip } = await supabase.from('trips').select('id,name,start_date,end_date,pax').eq('id', id).single();
if (!trip) return Astro.redirect('/trips');

const [{ data: itemsData }, { data: placesData }, { data: lodgingData }] = await Promise.all([
  supabase.from('itinerary_items').select('id,day,time,place_name,category,notes,cost,source,lat,lng').eq('trip_id', id).order('day').order('time'),
  supabase.from('trip_places').select('id,place_name,status,notes,lat,lng').eq('trip_id', id).order('created_at'),
  supabase.from('lodgings').select('name,address,lat,lng').eq('trip_id', id),
]);
const items = itemsData ?? [];
const wishlist = (placesData ?? []).filter((p: any) => p.status === 'wishlist');
const mapData = { tripId: id, lodgings: lodgingData ?? [], items, places: placesData ?? [] };

const byDay: Record<string, any[]> = {};
for (const it of items as any[]) (byDay[it.day ?? 'Unscheduled'] ??= []).push(it);
const back = `/trips/${id}/itinerary`;
---

<AppLayout title={`Itinerary · ${trip.name}`}>
  <p class="eyebrow">Itinerary</p>
  <h1>{trip.name}</h1>
  <div class="tabbar">
    <a href={`/trips/${id}`}>Details</a>
    <a href={`/trips/${id}/itinerary`} class="on">Itinerary</a>
    <a href={`/trips/${id}/map`}>Map</a>
    <a href={`/trips/${id}/budget`}>Budget</a>
    <a href={`/trips/${id}/today`}>Today</a>
  </div>

  <!-- Add item -->
  <form method="post" action="/api/itinerary-save" class="card rowflex">
    <input type="hidden" name="trip_id" value={id} />
    <input type="hidden" name="redirect" value={back} />
    <div style="flex:2;min-width:170px;"><label>Place / activity</label><input name="place_name" required placeholder="Victoria Peak sunset" /></div>
    <div style="width:140px;"><label>Date</label><input name="day" type="date" min={trip.start_date} max={trip.end_date} /></div>
    <div style="width:110px;"><label>Time</label><input name="time" type="time" /></div>
    <div style="width:130px;"><label>Category</label>
      <select name="category"><option>activity</option><option>food</option><option>transport</option><option>sight</option></select>
    </div>
    <button class="btn" type="submit" style="padding:11px 16px;">Add</button>
  </form>
  <p class="hint" style="margin-top:6px;">New places are located automatically and appear on the map below and in the day's route.</p>

  <!-- Live map of the itinerary -->
  <div class="card" style="margin-top:12px;">
    <h2><Icon name="map" /> Your route</h2>
    <div id="map" style="height:44vh;border-radius:14px;border:1px solid var(--line);"></div>
    <div id="route-summary" style="margin-top:10px;"></div>
    <p class="hint" style="margin-top:6px;">Same-day stops share a color; the dashed line traces your day in time order. Distances are straight-line between stops.</p>
  </div>

  <!-- Smart suggestions -->
  <div class="card" style="margin-top:12px;">
    <div class="rowflex" style="justify-content:space-between;">
      <h2 style="margin:0;">Smart suggestions</h2>
      <button class="mini" type="button" id="suggest-btn">Suggest for my dates</button>
    </div>
    <div id="suggestions" class="stack" style="margin-top:10px;"></div>
  </div>

  <!-- Places to visit -->
  <div class="section">
    <h2><Icon name="pin" /> Places to visit <span class="hint">(not scheduled yet)</span></h2>
    <div class="stack">
      {wishlist.map((p: any) => (
        <form method="post" action="/api/place-save" class="card rowflex">
          <input type="hidden" name="trip_id" value={id} />
          <input type="hidden" name="id" value={p.id} />
          <input type="hidden" name="redirect" value={back} />
          <div style="flex:1;min-width:140px;font-weight:700;">{p.place_name}</div>
          <div style="width:140px;"><label>Date</label><input name="day" type="date" min={trip.start_date} max={trip.end_date} /></div>
          <div style="width:110px;"><label>Time</label><input name="time" type="time" /></div>
          <button class="mini" type="submit" name="op" value="promote">→ Schedule</button>
          <button class="mini" type="submit" name="op" value="delete" style="color:var(--bad);" aria-label="Remove place">✕</button>
        </form>
      ))}
      {wishlist.length === 0 && <p class="hint">Nothing waiting — add places here, from the map, or via suggestions.</p>}
      <form method="post" action="/api/place-save" class="card rowflex" style="border-style:dashed;">
        <input type="hidden" name="trip_id" value={id} />
        <input type="hidden" name="redirect" value={back} />
        <div style="flex:1;min-width:180px;"><label>Add a place to visit</label><input name="place_name" required placeholder="Big Buddha, Lantau Island" /></div>
        <button class="btn" type="submit" style="padding:11px 16px;">Add</button>
      </form>
    </div>
  </div>

  <!-- Day by day (each stop opens for editing with the pencil) -->
  <div class="section">
    <h2>Day by day</h2>
    {Object.keys(byDay).length === 0 && <p class="hint">No itinerary items yet.</p>}
    {Object.entries(byDay).map(([day, list]) => (
      <div class="card" style="margin-bottom:12px;">
        <h2 style="color:var(--teal);">{day === 'Unscheduled' ? 'Unscheduled' : new Date(day + 'T00:00:00').toLocaleDateString(undefined, { weekday: 'long', month: 'short', day: 'numeric' })}</h2>
        <div class="stack">
          {list.map((it: any) => (
            <details class="edit-block" style="border-bottom:1px solid var(--line);padding-bottom:10px;">
              <summary>
                <div class="read" style="flex-direction:row;align-items:center;gap:10px;flex-wrap:wrap;">
                  <span style="min-width:52px;font-weight:700;">{it.time ? String(it.time).slice(0, 5) : '—'}</span>
                  <span style="flex:1;min-width:140px;">
                    <b>{it.place_name}</b> <span class="pill planning" style="font-size:.62rem;">{it.category ?? 'activity'}</span>
                    {it.source === 'ai' && <span class="pill active" style="font-size:.62rem;">suggested</span>}
                    {it.lat == null && <span class="pill archived" style="font-size:.62rem;">not on map</span>}
                    {it.notes && <span class="hint" style="display:block;">{it.notes}</span>}
                  </span>
                </div>
                <span class="row-toggle" data-closed="Edit" data-open="Close" aria-hidden="true"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></span>
              </summary>
              <form method="post" action="/api/itinerary-save" class="rowflex" style="margin-top:12px;">
                <input type="hidden" name="trip_id" value={id} />
                <input type="hidden" name="id" value={it.id} />
                <input type="hidden" name="redirect" value={back} />
                <input type="hidden" name="prev_name" value={it.place_name} />
                <div style="flex:2;min-width:160px;"><label>Place</label><input name="place_name" value={it.place_name} required /></div>
                <div style="width:140px;"><label>Date</label><input name="day" type="date" value={it.day ?? ''} min={trip.start_date} max={trip.end_date} /></div>
                <div style="width:110px;"><label>Time</label><input name="time" type="time" value={it.time ? String(it.time).slice(0, 5) : ''} /></div>
                <div style="width:120px;"><label>Category</label>
                  <select name="category">
                    {['activity', 'food', 'transport', 'sight'].map((c) => <option value={c} selected={(it.category ?? 'activity') === c}>{c}</option>)}
                  </select>
                </div>
                <div style="flex:2;min-width:160px;"><label>Notes</label><input name="notes" value={it.notes ?? ''} placeholder="tickets booked, wear shoes…" /></div>
                <button class="mini" type="submit">Save</button>
                <button class="mini" type="submit" name="op" value="delete" style="color:var(--bad);" onclick="return confirm('Remove this item?');" aria-label="Remove item">✕</button>
              </form>
            </details>
          ))}
        </div>
      </div>
    ))}
  </div>

  <script type="application/json" id="map-data" set:html={JSON.stringify(mapData)} />
  <script src="../../../scripts/trip-map.js"></script>

  <script is:inline define:vars={{ tripId: id, back }}>
    const btn = document.getElementById('suggest-btn');
    if (btn) btn.addEventListener('click', async () => {
      const host = document.getElementById('suggestions');
      host.innerHTML = '<span class="hint">Matching your destinations & month…</span>';
      btn.disabled = true;
      try {
        const res = await fetch('/api/recommend', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ trip_id: tripId }) });
        const j = await res.json();
        host.innerHTML = '';
        (j.suggestions ?? []).forEach((s) => {
          const d = document.createElement('div');
          d.className = 'rowflex';
          d.style.cssText = 'border-bottom:1px solid var(--line);padding-bottom:8px;align-items:center;';
          const img = s.img
            ? `<img src="${s.img}" alt="" loading="lazy" style="width:64px;height:48px;object-fit:cover;border-radius:8px;flex:0 0 64px;border:1px solid var(--glass-edge);">`
            : `<span style="width:64px;height:48px;flex:0 0 64px;border-radius:8px;background:rgba(15,118,110,.08);display:inline-flex;align-items:center;justify-content:center;color:var(--teal);"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Z"/><circle cx="12" cy="11" r="2.2"/></svg></span>`;
          d.innerHTML = `${img}<div style="flex:1;min-width:150px;"><b></b> <span class="pill active" style="font-size:.62rem;">${s.category}</span><div class="hint"></div></div>`;
          d.querySelector('b').textContent = s.name;
          d.querySelector('.hint').textContent = s.why + (s.best_time ? ' · ' + s.best_time : '');
          const add = document.createElement('button');
          add.className = 'mini'; add.type = 'button'; add.textContent = '+ Add to places';
          add.addEventListener('click', async () => {
            await fetch('/api/place-save', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ op: 'add', trip_id: tripId, place_name: s.name, notes: s.why }) });
            location.href = back;
          });
          d.appendChild(add);
          host.appendChild(d);
        });
        if (!(j.suggestions ?? []).length) host.innerHTML = '<span class="hint">' + (j.error ?? 'No suggestions right now.') + '</span>';
      } catch { host.innerHTML = '<span class="hint">Could not fetch suggestions.</span>'; }
      btn.disabled = false;
    });
  </script>
</AppLayout>
