---
import AppLayout from '../layouts/AppLayout.astro';
import { COUNTRIES } from '../lib/countries';
import { PASSWORD_RULE } from '../lib/password';
const err = Astro.url.searchParams.get('error');
const confirm = Astro.url.searchParams.has('confirm');
---
<AppLayout title="Create account · WanderWise">
  <div style="max-width:400px;margin:6vh auto 0;">
    <h1>Create your account</h1>
    <p class="lede">Free while we build. No card needed.</p>
    {err && <div class="alert alert-error">{decodeURIComponent(err)}</div>}
    {confirm ? (
      <div class="alert alert-ok">Check your inbox — confirm your email, then sign in.</div>
    ) : (
      <>
      <form method="post" action="/api/signup" class="card stack">
        <div><label for="name">Name</label><input id="name" name="display_name" type="text" required placeholder="Ken R." /></div>
        <div><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required /></div>
        <div>
          <label for="country">Passport country</label>
          <select id="country" name="passport_country" autocomplete="country-name">
            <option value="">Select your country…</option>
            {COUNTRIES.map((c) => <option value={c.name}>{c.name}</option>)}
          </select>
          <p class="hint" style="margin-top:4px;">Powers visa &amp; entry-requirement checks on your trips. You can change it later in Account.</p>
        </div>
        <div>
          <label for="password">Password</label>
          <input id="password" name="password" type="password" autocomplete="new-password" required minlength="10" placeholder="10+ characters" />
          <div class="pw-meter" id="pwMeter"><span></span><span></span><span></span><span></span></div>
          <p class="pw-msg" id="pwMsg">{PASSWORD_RULE}</p>
        </div>
        <div>
          <label for="password2">Confirm password</label>
          <input id="password2" name="password2" type="password" autocomplete="new-password" required minlength="10" />
          <p class="pw-msg" id="pwMatch"></p>
        </div>
        <button class="btn" type="submit">Create account</button>
      </form>
      <script is:inline>
        (function(){
          var i=document.getElementById('password'), m=document.getElementById('pwMeter'), msg=document.getElementById('pwMsg');
          var i2=document.getElementById('password2'), match=document.getElementById('pwMatch');
          var form=i ? i.closest('form') : null;
          if(!i) return;
          var RULE=msg.textContent;
          i.addEventListener('input',function(){
            var pw=i.value, n=0;
            if(pw.length>=10)n++; if(pw.length>=14)n++;
            var cl=[/[a-z]/,/[A-Z]/,/[0-9]/,/[^A-Za-z0-9]/].filter(function(r){return r.test(pw)}).length;
            n+=Math.max(0,cl-1); n=Math.min(4,n);
            m.className='pw-meter'+(pw?' s'+n:'');
            msg.textContent = !pw ? RULE : (n<=1?'Weak — add length and variety.':n===2?'Fair — add another character type.':n===3?'Good.':'Strong.');
            checkMatch();
          });
          var checkMatch=function(){
            if(!i2.value){ match.textContent=''; i2.setCustomValidity(''); return; }
            var ok = i2.value === i.value;
            match.textContent = ok ? 'Passwords match.' : "Passwords don't match yet.";
            match.style.color = ok ? 'var(--ok)' : 'var(--bad)';
            i2.setCustomValidity(ok ? '' : "Passwords don't match.");
          };
          i2.addEventListener('input', checkMatch);
          if(form) form.addEventListener('submit', function(e){
            if(i2.value !== i.value){ e.preventDefault(); checkMatch(); i2.focus(); }
          });
        })();
      </script>
      <div class="card" style="margin-top:12px;text-align:center;">
        <a class="btn btn-outline" href="/api/oauth-google" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;">
          <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
          Continue with Google
        </a>
      </div>
      <p class="hint" style="text-align:center;margin-top:10px;">Already have one? <a href="/login">Sign in</a></p>
      </>
    )}
  </div>
</AppLayout>
