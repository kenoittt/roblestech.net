---
import AppLayout from '../layouts/AppLayout.astro';
import { loadPpmData, nameOf } from '../lib/queries';

const { all: tasks, people } = await loadPpmData(Astro);

const todo = tasks.filter((t) => t.status === 'todo').length;
const prog = tasks.filter((t) => t.status === 'in_progress').length;
const done = tasks.filter((t) => t.status === 'done').length;

const now = new Date();
const day = (now.getUTCDay() + 6) % 7;
const monThis = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - day));
const monLast = new Date(monThis); monLast.setUTCDate(monThis.getUTCDate() - 7);
const inRange = (iso: string | null, a: Date, b: Date) => (iso ? new Date(iso) >= a && new Date(iso) < b : false);
const doneThisWeek = tasks.filter((t) => inRange(t.completed_at, monThis, new Date(now.getTime() + 86400000))).length;
const doneLastWeek = tasks.filter((t) => inRange(t.completed_at, monLast, monThis)).length;

// Per-member workload (open tasks = todo + in progress).
const rows = people.map((p) => {
  const mine = tasks.filter((t) => t.assignee_id === p.id);
  return {
    id: p.id,
    name: p.full_name || '(no name)',
    todo: mine.filter((t) => t.status === 'todo').length,
    prog: mine.filter((t) => t.status === 'in_progress').length,
    done: mine.filter((t) => t.status === 'done').length,
    week: mine.filter((t) => inRange(t.completed_at, monThis, new Date(now.getTime() + 86400000))).length,
  };
});
const unassigned = tasks.filter((t) => !t.assignee_id && t.status !== 'done').length;
// Due soon (next 7 days, not done)
const in7 = new Date(now.getTime() + 7 * 86400000).toISOString().slice(0, 10);
const today = now.toISOString().slice(0, 10);
const dueSoon = tasks
  .filter((t) => t.status !== 'done' && t.due_date && t.due_date <= in7)
  .sort((a, b) => String(a.due_date).localeCompare(String(b.due_date)))
  .slice(0, 8);
---

<AppLayout title="Dashboard · Robles Tech PPM">
  <p class="eyebrow">Project Management</p>
  <h1>Dashboard</h1>
  <p class="lede">The team's work at a glance. Jump to the <a href="/board" style="color:var(--green);">Board</a> or the <a href="/tasks" style="color:var(--green);">Tasks sheet</a>.</p>

  <div class="stats">
    <div class="stat todo"><div class="n">{todo}</div><div class="l">Not started</div></div>
    <div class="stat prog"><div class="n">{prog}</div><div class="l">In progress</div></div>
    <div class="stat done"><div class="n">{done}</div><div class="l">Done (all time)</div></div>
    <div class="stat week"><div class="n">{doneThisWeek}</div><div class="l">Finished this week</div></div>
    <div class="stat week"><div class="n">{doneLastWeek}</div><div class="l">Finished last week</div></div>
  </div>

  <div class="dash-grid">
    <div class="card">
      <h2 style="font-size:1.05rem;margin-bottom:14px;">Workload by member</h2>
      <table class="ttable" style="min-width:0;">
        <thead><tr><th>Member</th><th class="num">To do</th><th class="num">In progress</th><th class="num">Done</th><th class="num">This week</th><th></th></tr></thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="c-title">{r.name}</td>
              <td class="num">{r.todo}</td>
              <td class="num">{r.prog}</td>
              <td class="num">{r.done}</td>
              <td class="num" style="color:var(--green);font-weight:700;">{r.week}</td>
              <td style="text-align:right;"><a href={`/tasks?assignee=${r.id}`} style="color:var(--azure);font-size:.8rem;font-weight:700;text-decoration:none;">View →</a></td>
            </tr>
          ))}
          {unassigned > 0 && (
            <tr>
              <td class="c-title" style="color:var(--muted);">Unassigned</td>
              <td class="num" colspan="4" style="text-align:left;color:var(--muted);">{unassigned} open task{unassigned === 1 ? '' : 's'}</td>
              <td style="text-align:right;"><a href="/tasks?assignee=none" style="color:var(--azure);font-size:.8rem;font-weight:700;text-decoration:none;">View →</a></td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2 style="font-size:1.05rem;margin-bottom:14px;">Due in the next 7 days</h2>
      {dueSoon.length === 0 ? (
        <p class="hint" style="margin:0;">Nothing due soon. 🎉</p>
      ) : (
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:9px;">
          {dueSoon.map((t) => (
            <li style="display:flex;justify-content:space-between;gap:10px;font-size:.9rem;border-bottom:1px solid rgba(255,255,255,0.06);padding-bottom:8px;">
              <span>{t.title} <span class="hint">· {nameOf(people, t.assignee_id)}</span></span>
              <span style={`white-space:nowrap;font-weight:700;color:${t.due_date! < today ? '#ff8a8a' : 'var(--azure)'};`}>{t.due_date! < today ? 'overdue ' : ''}{t.due_date}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</AppLayout>
