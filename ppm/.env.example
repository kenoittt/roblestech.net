# Copy to .env and fill in. Never commit the real .env.

# --- Supabase (same project as the client portal) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Microsoft 365 email (Microsoft Graph, client-credentials) ---
# From your Entra ID app registration with Mail.Send application permission.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# The mailbox notifications are sent from, e.g. notifications@roblestech.net
MAIL_FROM=

# --- Cron auth (invent a long random string) ---
CRON_SECRET=

# Base URL used in email links (e.g. https://ppm.roblestech.net)
PUBLIC_APP_URL=https://ppm.roblestech.net
